<figure class="<!-- $cssClass? -->">
	<picture>
		<source media="(min-width: 768px)" srcset="_media/<!-- $imageName? -->-l.jpg" />
		<source media="(min-width: 658px)" srcset="_media/<!-- $imageName? -->-m.jpg" />
		<img src="_media/<!-- $imageName? -->-s.jpg" alt="" />
	</picture>
	<figcaption><!-- $figcaption? --></figcaption>
</figure>
